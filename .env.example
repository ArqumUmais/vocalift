# ═══════════════════════════════════════════════════
#  Vocalift — Environment Configuration
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key

FLASK_ENV=production
PORT=5555

# Your domain or IP (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Rate limits
RATE_LIMIT_INFO=60 per minute
RATE_LIMIT_CONVERT=3 per minute
RATE_LIMIT_DOWNLOAD=20 per minute
RATE_LIMIT_GLOBAL=100 per minute

# Job settings
MAX_CONCURRENT_JOBS=3
MAX_DURATION_SECONDS=1800
JOB_TTL_SECONDS=3600

# Storage
WORK_DIR=./vocalift_work
OUT_DIR=./vocalift_output
MAX_DISK_GB=20

# HTTPS (set true when behind Nginx with SSL)
FORCE_HTTPS=false

LOG_LEVEL=INFO
LOG_DIR=./logs
